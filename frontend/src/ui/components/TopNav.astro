---
import { testScope, testId } from '@lib/testid';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

// Strip trailing slash from BASE_URL so we can prepend it to paths that start with '/'.
// Dev:  BASE_URL = '/'        → prefix = ''
// Prod: BASE_URL = '/bjj-open-mats-mn/' → prefix = '/bjj-open-mats-mn'
const prefix = import.meta.env.BASE_URL.replace(/\/$/, '');

const SCOPE = testScope(import.meta);  // → "ui:topnav"

const navLinks = [
  { path: '/', label: 'Home' },
  { path: '/calendar', label: 'Calendar' },
  { path: '/gyms', label: 'Gyms' },
  { path: '/settings', label: 'Settings' },
];
---

<nav class="top-nav">
  <a href={prefix + '/'} class="top-nav__brand" {...testId(SCOPE, 'brand')}>BJJ Open Mats</a>
  <div class="top-nav__links" id="nav-links">
    {navLinks.map(link => (
      <a
        href={prefix + link.path}
        class="top-nav__link"
        aria-current={currentPath === link.path ? 'page' : undefined}
        {...testId(SCOPE, 'nav', link.label)}
      >
        {link.label}
      </a>
    ))}
  </div>
  <button class="top-nav__toggle" id="nav-toggle" aria-label="Toggle navigation" {...testId(SCOPE, 'mobile-toggle')}>
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <line x1="3" y1="4.5" x2="15" y2="4.5"/>
      <line x1="3" y1="9" x2="15" y2="9"/>
      <line x1="3" y1="13.5" x2="15" y2="13.5"/>
    </svg>
  </button>
</nav>
